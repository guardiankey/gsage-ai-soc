# gSage AI — CLI Client Environment Variables
#
# Copy this to your shell profile or export before running:
#   source cli_client/.env.example

# ── API host ──────────────────────────────────────────────────────────────────
# Optional: defaults to http://localhost:8000
GSAGE_API_HOST=http://localhost:8000

# ── Authentication (choose one option) ───────────────────────────────────────

# Option A — Static API key  (requires GSAGE_ORG_ID)
# Recommended: create a personal API key with interface="cli" via the web UI
# or API endpoint (POST /v1/orgs/{org_id}/me/api-keys, body: {"interface":"cli"}).
# Keys with interface="cli" receive terse, terminal-friendly responses without
# heavy markdown formatting.
# GSAGE_API_KEY=gk_live_your-api-key-here
# GSAGE_ORG_ID=your-org-uuid-here

# Option B — Email + password (auto-login at startup, org_id from JWT)
# GSAGE_EMAIL=you@example.com
# GSAGE_PASSWORD=your-password

# Option C — No env vars; type  'login'  inside the REPL

# ── Session ───────────────────────────────────────────────────────────────────
# Optional: resume a specific conversation by UUID
# GSAGE_CONVERSATION_ID=uuid-of-existing-conversation

# ── Output ────────────────────────────────────────────────────────────────────
# Optional: enable debug mode (true/false)
# GSAGE_DEBUG=false

# Optional: output format (markdown/plain)
# GSAGE_OUTPUT_FORMAT=markdown
