# AUTO-GENERATED by scripts/generate_channels_docs.py — do not edit manually.
# Derived from each channel's `CHANNEL_SPEC.env_vars`.
# Fill in the values that apply to your deployment in your real `.env`.
#
# Sensitive fields are emitted with a placeholder `__SET_ME__`. NEVER commit
# real secrets to git — use `.env`, a secret manager, or the encrypted DB row.
#
# Per-organisation settings (bot tokens, IMAP credentials, etc.) are NOT
# listed here — they live in the database and are managed via
# `python -m ops_cli channels …`.
#


# === Email Channel ===

# When ``true`` permanently delete messages after processing; otherwise they are only marked ``\Seen``.
EMAIL_DELETE_AFTER_PROCESS=false

# Maximum inbound messages processed per organisation per UTC day.
EMAIL_RATE_LIMIT_ORG_DAILY=100

# Maximum new threads opened per user per rolling hour.
EMAIL_RATE_LIMIT_USER_HOURLY=10

# IMAP folder where messages from unknown senders are moved (auto-created on first use).
EMAIL_UNKNOWN_SENDER_FOLDER=Unknown-Senders

# Default body format for outbound notifications: ``html`` (auto-converts Markdown) or ``text``.
SMTP_DEFAULT_FORMAT=html

# Fallback From address for outbound SOC notifications that are not tied to a specific account.
SMTP_FROM_EMAIL=noreply@gsage.local

# Display name paired with ``SMTP_FROM_EMAIL``.
SMTP_FROM_NAME=gSage AI


# === Teams Channel ===

# Microsoft Bot Framework public OpenID configuration URL — override only for sovereign / gov clouds.
TEAMS_BOT_OPENID_METADATA_URL=https://login.botframework.com/v1/.well-known/openidconfiguration

# Cache TTL (s) for AAD-Object-ID → email lookups via Microsoft Graph (first-contact resolution only).
TEAMS_GRAPH_EMAIL_CACHE_TTL=86400

# Outbound chunk size before splitting (Teams hard cap on a single text activity is 28 KB).
TEAMS_MAX_MESSAGE_LENGTH=25000

# Maximum activities forwarded per organisation per UTC day.
TEAMS_RATE_LIMIT_ORG_DAILY=200

# Maximum activities forwarded per Teams user per rolling hour.
TEAMS_RATE_LIMIT_USER_HOURLY=30


# === Telegram Channel ===

# Outbound chunk size before splitting (Telegram hard cap is 4096 characters).
TELEGRAM_MAX_MESSAGE_LENGTH=4096

# Maximum messages forwarded per organisation per UTC day.
TELEGRAM_RATE_LIMIT_ORG_DAILY=200

# Maximum messages forwarded per Telegram user per rolling hour.
TELEGRAM_RATE_LIMIT_USER_HOURLY=30

# Interval (s) between DB scans to discover new / deactivated bot profiles. ``0`` disables hot-reload.
TELEGRAM_RELOAD_INTERVAL=300
