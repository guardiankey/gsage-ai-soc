{
  "name": "InteractiveSessions",
  "page_title": "InteractiveSessions collector",
  "summary": "The InteractiveSessions collector gathers information about live interactive sessions on managed devices.",
  "supported_os": {
    "windows": "3.0 and later",
    "linux": "3.0 and later",
    "macos": "3.0 and later"
  },
  "fields": [
    {
      "name": "userid",
      "type": "String",
      "description": "The user name that is logged into the session."
    },
    {
      "name": "name",
      "type": "String",
      "description": "The user's full name. Note This field is not reported for non-local users."
    }
  ],
  "examples": [
    {
      "title": "Example: Show interactive sessions for user 'owilde'",
      "v2_query": "InteractiveSessions where InteractiveSessions userid equals \"owilde\""
    }
