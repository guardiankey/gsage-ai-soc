{
  "name": "LoggedInUsers",
  "page_title": "LoggedInUsers collector",
  "summary": "The LoggedInUsers collector gathers data about users logged into managed systems.",
  "supported_os": {
    "windows": "3.0 and later",
    "linux": "3.0 and later",
    "macos": "3.0 and later"
  },
  "fields": [
    {
      "name": "id",
      "type": "String",
      "description": "The user ID set by the operating system."
    },
    {
      "name": "userdomain",
      "type": "String",
      "description": "The domain where the user belongs."
    },
    {
      "name": "username",
      "type": "String",
      "description": "The logon user name."
    }
  ],
  "examples": [
    {
      "title": "Example: Show users logged under the \"RISK\" domain",
      "v2_query": "LoggedInUsers where LoggedInUsers userdomain equals \"RISK\""
    }
  ],
