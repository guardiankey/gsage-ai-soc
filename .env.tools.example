# === Smtp Send Tools ===

# Optional allowlist of regex patterns.  A recipient is accepted when it matches at least one pattern or when it is one of the current user's own addresses.  When empty, the behaviour depends on the tool variant: ``send_email`` accepts any recipient (approval already gates the action); ``send_email_direct`` restricts delivery to the current user's own addresses.
TOOL_SMTP_SEND__ALLOWED_RECIPIENTS_REGEX=

# Default body format (overrides SMTP_DEFAULT_FORMAT).
TOOL_SMTP_SEND__SMTP_DEFAULT_FORMAT=

# Sender address in the From header (overrides SMTP_FROM_EMAIL).
TOOL_SMTP_SEND__SMTP_FROM_EMAIL=

# Sender display name in the From header (overrides SMTP_FROM_NAME).
TOOL_SMTP_SEND__SMTP_FROM_NAME=

# SMTP server hostname (overrides SMTP_HOST).
TOOL_SMTP_SEND__SMTP_HOST=

# SMTP authentication password (overrides SMTP_PASSWORD).
TOOL_SMTP_SEND__SMTP_PASSWORD=

# SMTP port (overrides SMTP_PORT).
TOOL_SMTP_SEND__SMTP_PORT=

# Use STARTTLS for the SMTP connection (overrides SMTP_USE_TLS).
TOOL_SMTP_SEND__SMTP_USE_TLS=

# SMTP authentication username (overrides SMTP_USERNAME).
TOOL_SMTP_SEND__SMTP_USERNAME=

# Validate TLS server certificate (default true).  Set to false only for internal relays using self-signed certificates.
TOOL_SMTP_SEND__SMTP_VALIDATE_CERTS=


# === Ssh Command ===

# --- override: ssh_command ---
# IPv4/IPv6 CIDR blocks that a dynamic hostname must resolve into. When the hostname does not match any allowed_host_patterns, it is resolved via DNS and the resulting IP is checked against these CIDRs. The resolved IP is used for the SSH connection to prevent DNS rebinding. Example: ['192.168.10.0/24', '10.0.0.0/8']
TOOL_SSH_COMMAND__ALLOWED_CIDRS=[]

# Regex allow list for arbitrary commands (used by ssh_command tool only). At least one pattern must match the command for it to be executed. When empty, all commands are allowed (subject to the deny list). Example: ['^ps\\b', '^tail\\b', '^cat\\s+/var/log/']
TOOL_SSH_COMMAND__ALLOWED_COMMAND_PATTERNS=[]

# Regex patterns tested with re.fullmatch (case-insensitive) against the hostname supplied by the LLM for dynamic host access. When a pattern matches, the hostname is allowed without DNS resolution. Use anchored patterns to prevent substring bypass. Example: ['^192\\.168\\.10\\.\\d+$', '^[a-z0-9-]+\\.internal\\.example\\.com$']
TOOL_SSH_COMMAND__ALLOWED_HOST_PATTERNS=[]

# Seconds to wait for the remote command to complete. Default: 30.
TOOL_SSH_COMMAND__COMMAND_TIMEOUT_SECONDS=30

# Seconds to wait for SSH TCP connection. Default: 10.
TOOL_SSH_COMMAND__CONNECTION_TIMEOUT_SECONDS=10

# Named credential profiles for dynamic host access. The LLM selects a profile by key when using the 'hostname' parameter.
TOOL_SSH_COMMAND__CREDENTIAL_PROFILES=[]

# Regex deny list applied to ALL commands on both tools. Commands matching any pattern are blocked. Example: ['^sudo\\b', 'wget\\s+.*\\|\\s*(ba)?sh']
TOOL_SSH_COMMAND__DENIED_COMMAND_PATTERNS=[]

# List of SSH hosts available for this tool.
TOOL_SSH_COMMAND__HOSTS=[]

# Maximum bytes to capture from stdout + stderr combined. Default: 65536.
TOOL_SSH_COMMAND__MAX_OUTPUT_BYTES=65536

# Pre-defined commands that can be run without approval.
TOOL_SSH_COMMAND__PRESET_COMMANDS=[]


# === Ssh Command Preset ===

# --- override: ssh_command_preset ---
# IPv4/IPv6 CIDR blocks that a dynamic hostname must resolve into. When the hostname does not match any allowed_host_patterns, it is resolved via DNS and the resulting IP is checked against these CIDRs. The resolved IP is used for the SSH connection to prevent DNS rebinding. Example: ['192.168.10.0/24', '10.0.0.0/8']
TOOL_SSH_COMMAND_PRESET__ALLOWED_CIDRS=[]

# Regex allow list for arbitrary commands (used by ssh_command tool only). At least one pattern must match the command for it to be executed. When empty, all commands are allowed (subject to the deny list). Example: ['^ps\\b', '^tail\\b', '^cat\\s+/var/log/']
TOOL_SSH_COMMAND_PRESET__ALLOWED_COMMAND_PATTERNS=[]

# Regex patterns tested with re.fullmatch (case-insensitive) against the hostname supplied by the LLM for dynamic host access. When a pattern matches, the hostname is allowed without DNS resolution. Use anchored patterns to prevent substring bypass. Example: ['^192\\.168\\.10\\.\\d+$', '^[a-z0-9-]+\\.internal\\.example\\.com$']
TOOL_SSH_COMMAND_PRESET__ALLOWED_HOST_PATTERNS=[]

# Seconds to wait for the remote command to complete. Default: 30.
TOOL_SSH_COMMAND_PRESET__COMMAND_TIMEOUT_SECONDS=30

# Seconds to wait for SSH TCP connection. Default: 10.
TOOL_SSH_COMMAND_PRESET__CONNECTION_TIMEOUT_SECONDS=10

# Named credential profiles for dynamic host access. The LLM selects a profile by key when using the 'hostname' parameter.
TOOL_SSH_COMMAND_PRESET__CREDENTIAL_PROFILES=[]

# Regex deny list applied to ALL commands on both tools. Commands matching any pattern are blocked. Example: ['^sudo\\b', 'wget\\s+.*\\|\\s*(ba)?sh']
TOOL_SSH_COMMAND_PRESET__DENIED_COMMAND_PATTERNS=[]

# List of SSH hosts available for this tool.
TOOL_SSH_COMMAND_PRESET__HOSTS=[]

# Maximum bytes to capture from stdout + stderr combined. Default: 65536.
TOOL_SSH_COMMAND_PRESET__MAX_OUTPUT_BYTES=65536

# Pre-defined commands that can be run without approval.
TOOL_SSH_COMMAND_PRESET__PRESET_COMMANDS=[]


