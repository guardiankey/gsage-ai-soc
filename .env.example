# TOOL_TRELLIX_EDR__REGION=us-east-1
# HTTP request timeout in seconds (default: 60).
# TOOL_TRELLIX_EDR__TIMEOUT=60
# Override the OAuth2 token endpoint.  Default: https://auth.trellix.com/auth/realms/IAM/protocol/openid-connect/token.
# TOOL_TRELLIX_EDR__TOKEN_URL=https://auth.trellix.com/auth/realms/IAM/protocol/openid-connect/token
# Verify TLS certificates (default: true).
# TOOL_TRELLIX_EDR__VERIFY_TLS=true
