# =============================================================================
# gSage AI — Environment Variables
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
# DEBUG=false in production
DEBUG=true
# AES-256-GCM key for encrypting sensitive DB fields (32 bytes, base64-encoded)
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=CHANGE-ME-base64-encoded-32-bytes

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=gsagekey
POSTGRES_USER=gsagekey
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy async pool sizing for the MCP / API processes. Increase if
# the LLM agent fans out many parallel tool calls and you start seeing
# pool checkout timeouts. Total max connections per process =
# DATABASE_POOL_SIZE + DATABASE_MAX_OVERFLOW.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
# Recycle pooled connections every N seconds (defends against silent
# drops by load balancers / firewalls).
DATABASE_POOL_RECYCLE_SECONDS=1800
# Postgres-side safety nets, in milliseconds. statement_timeout aborts
# any single query that exceeds the limit; idle_in_transaction_session_timeout
# kills connections left mid-transaction with no further activity (prevents
# "idle in transaction" zombies if a client is cancelled mid-flight).
# Set to 0 to disable.
DATABASE_STATEMENT_TIMEOUT_MS=20000
DATABASE_IDLE_IN_TX_TIMEOUT_MS=30000

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE-ME-strong-password
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=gsage-
ELASTICSEARCH_TRACE_INDEX_PREFIX=gsage-
ELASTICSEARCH_TRACE_RETENTION_DAYS=90
# Redis buffer flush: interval (seconds) between Celery flush cycles and max
# documents popped from the buffer per cycle.
ELASTICSEARCH_BUFFER_FLUSH_INTERVAL=60
ELASTICSEARCH_BUFFER_MAX_BATCH=5000

# ── Weaviate (Vector DB for Knowledge Base) ─────────────────
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
# Leave empty if Weaviate authentication is disabled (default for on-prem)
WEAVIATE_API_KEY=
# gRPC/REST init timeout in seconds. Raise (e.g. 60) if you see
# "WeaviateGRPCUnavailableError: Deadline Exceeded" during startup or
# ingest under load. Default is 30s.
WEAVIATE_INIT_TIMEOUT=30
# Skip client-side startup health checks. Set to true as a workaround when
# the gRPC port is reachable but slow to answer pings during warm-up.
WEAVIATE_SKIP_INIT_CHECKS=false

# ── anyio CancelScope spin-guard ─────────────────────────────
# Diagnostic guard that breaks ``CancelScope._deliver_cancellation`` busy
# loops (uncancellable tasks pinning the event loop at 100 % CPU). When
# tripped, the guard logs the offending scope's tasks and breaks the
# spin so the worker recovers. Set to 0 to disable (not recommended).
ANYIO_SPIN_GUARD=1
# Consecutive _deliver_cancellation retries before the guard intervenes.
ANYIO_SPIN_THRESHOLD=500
# If the spin persists after the break, log a warning every N retries.
ANYIO_SPIN_LOG_INTERVAL=5000

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=600
RATE_LIMIT_USER_RPM=300

# ── Public application URL ──────────────────────────────────
# Absolute base URL where end-user devices reach the gSage web
# application.  Used to build absolute links delivered to users via
# channels that have no notion of origin (Telegram, e-mail) — e.g.
# knowledge-base download citations rendered inside agent answers.
# Must include scheme and host, no trailing slash.
PUBLIC_BASE_URL=http://localhost:3000

# ── LLM Provider ─────────────────────────────────────────────
# Valid values: ollama | openai | deepseek | anthropic | gemini
LLM_PROVIDER=ollama

# ── Ollama (Managed — gsage-ollama container) ──────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
# LLM maker model (optional — leave empty to start in embedding-only mode).
# Set to a model name to pull it automatically on container startup.
# Example: OLLAMA_MAKER_MODEL=llama3.1:8b
OLLAMA_MAKER_MODEL=
# Custom embedding model created at container startup with expanded num_ctx.
# Base model pulled automatically: nomic-embed-text (768 dimensions).
# Change OLLAMA_EMBED_NUM_CTX to 4096 if your GPU has limited VRAM.
OLLAMA_EMBEDDING_MODEL=nomic-embed-ctx8k
OLLAMA_EMBED_NUM_CTX=8192

# Max characters per chunk during document ingestion. Must stay well below
# OLLAMA_EMBED_NUM_CTX converted to characters (1 token ≈ 3-4 chars for
# English/PT, less for dense/base64/tables). 2500 is safe for an 8k-ctx embedder.
INGEST_CHUNK_SIZE=2500

# ── OpenAI (optional — leave empty if using Ollama) ──────────
# Set OPENAI_BASE_URL to use any OpenAI-compatible endpoint (e.g. local LM Studio)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MAKER_MODEL=gpt-4o-mini

# ── Google Gemini (optional — leave empty if using Ollama) ──────────
gemini_api_key=
gemini_maker_model=gemini-3.1-flash-lite-preview

# ── DeepSeek (optional — leave empty if using Ollama) ────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAKER_MODEL=deepseek-v4-flash

# ── Anthropic (optional — leave empty if using Ollama) ───────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MAKER_MODEL=claude-3-5-haiku-latest

# ── vLLM (self-hosted, optional) ─────────────────────────────
# Use for locally hosted vLLM servers (Gemma, Llama, etc.)
# IMPORTANT: start vLLM with tool call support enabled:
#   vllm serve <model> --enable-auto-tool-choice --tool-call-parser pythonic
# Without --tool-call-parser, tool calls leak as raw text in streaming mode.
LLM_PROVIDER=vllm
VLLM_API_KEY=EMPTY
VLLM_BASE_URL=http://192.168.15.78:8000/v1
VLLM_MAKER_MODEL=google/gemma-4-E4B-it
# Client-side recovery of tool calls leaked as plain text during streaming.
# Some vLLM tool-call parsers (e.g. gemma4) only emit proper tool_calls when
# stream=false; in streaming mode the raw markup escapes into content.
#   gemma → detect/convert Gemma 4 pythonic tool-call blocks
#   qwen  → detect/convert Qwen/Hermes <tool_call>{json}</tool_call> blocks
#           (alias: hermes). Use with vLLM --tool-call-parser hermes.
#   none  → disable text parsing (native tool_calls still pass through)
VLLM_TOOL_CALL_PARSER=gemma
# Robustness fallback: serve streaming requests via a single non-streaming
# call internally (where vLLM emits correct tool_calls), then replay as one
# delta. Set true only if the text parser is insufficient for your model.
VLLM_FORCE_NON_STREAMING=false
# Hybrid "thinking" models (e.g. Qwen3) may spend the whole turn reasoning and
# finish by narrating the action in plain text instead of emitting a tool call.
# Set false to disable thinking (sent as chat_template_kwargs.enable_thinking)
# so the model calls tools directly. Leave empty to keep the model default.
#   VLLM_ENABLE_THINKING=false   → recommended for Qwen3 reasoning models
VLLM_ENABLE_THINKING=
# Diagnostic: when set to a writable directory, every outgoing request to vLLM
# is dumped as JSON (messages + tools + tool_choice + extra_body) so it can be
# replayed by limbo/debug_vllm_toolcalls.py --replay <file>.
# WARNING: dumps contain full prompts and history (PII). Dev/diagnostic only.
#   VLLM_DEBUG_REQUEST_DUMP_PATH=/tmp/vllm-dumps
VLLM_DEBUG_REQUEST_DUMP_PATH=
# ── Agent system prompt (optional) ──────────────────────────
# Overrides the built-in default system prompt for ALL agents globally.
# The org-level system_prompt (set per-org via UI/API) is always appended
# after this base prompt, so org customizations are preserved.
# Leave empty to use the built-in cybersecurity-focused default prompt.
# Use this only as a last resort when you need to change the base behavior
# for the entire platform (e.g., rebrand as a different AI persona).
# AGENT_DEFAULT_SYSTEM_PROMPT=
# ── Agent context control ─────────────────────────────────────
# Number of past turns included in the LLM context (default: 5).
# Increase for longer conversational memory; decrease to save tokens.
AGENT_NUM_HISTORY_RUNS=5
# Max characters of a single tool output stored in agent history (default: 40000).
# Outputs larger than this are truncated with a notice, preventing context overflow.
# Set to 0 to disable truncation (not recommended).
AGENT_TOOL_OUTPUT_MAX_CHARS=40000
# ── Knowledge base auto-injection (per-turn preamble) ────────
# When enabled, every chat turn prepends a short <kb_hints> block to the
# user message containing the most relevant saved notes/memories for the
# current user/org. This nudges the LLM to use saved memories without
# forcing a search_knowledge_base call.
# Set to "false" to disable the per-turn lookup entirely (saves one
# Weaviate round-trip per turn at the cost of less consistent recall).
KB_AUTO_INJECT_ENABLED=true
# Minimum Weaviate similarity score (0..1) required for a note to be
# auto-injected. Higher = tighter (less noise); lower = more permissive.
KB_AUTO_INJECT_MIN_SCORE=0.65
# Top-N user-private notes included in the preamble.
KB_AUTO_INJECT_USER_TOP_N=1
# Top-N org-wide / dept-wide notes included in the preamble.
KB_AUTO_INJECT_SHARED_TOP_N=2
# Maximum characters of each note preview shown in the preamble.
KB_AUTO_INJECT_PREVIEW_CHARS=200
# ── Agno telemetry ───────────────────────────────────────────
# Agno phones home to https://os-api.agno.com/telemetry/runs by default.
# We hardcode telemetry=False on every Agent we build, but this env var
# also disables it at the SDK level for any indirect Agent() construction
# (e.g. inside toolkits). Leave set to "false" for self-hosted deployments.
AGNO_TELEMETRY=false
# ── Agno session lock (chat concurrency control) ─────────────
# Prevents the SSE chat path and a background-tool continuation (Celery)
# from running ``agent.arun()`` on the same Agno session concurrently —
# which would race the post-hook history persistence and cause messages
# to disappear from the conversation.
# Bounded wait (seconds) when an incoming chat request finds the session
# busy with another in-flight run. On timeout, the user receives a
# "session busy, try again" response with HTTP 409.
AGNO_SESSION_LOCK_WAIT_SECONDS=5
# Safety TTL (seconds) — the Redis lock auto-expires if the holder crashes,
# preventing deadlock. Should comfortably exceed the longest expected
# single agent run.
AGNO_SESSION_LOCK_TTL_SECONDS=120
# ── MCP Server ───────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8001
# Read timeout in seconds for MCP tool calls (default: 120s for slow tools like wikijs_editor)
MCP_TOOL_TIMEOUT_SECONDS=60

# ── Mermaid validator tool ───────────────────────────────────
# Path to the mermaid-cli binary inside the mcp_server container.
# The Dockerfile installs @mermaid-js/mermaid-cli globally, so `mmdc` is on PATH.
MERMAID_CLI_BIN=mmdc
# Hard timeout (seconds) for a single mmdc validation/render call.
# First call after container start is slower due to Chromium warm-up.
MERMAID_VALIDATE_TIMEOUT_SECONDS=45

# ── Docker Compose ───────────────────────────────────────────
# Used only by docker-compose.yml for port mapping (not by Python code)
BACKEND_PORT=8000

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-at-least-32-random-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CRUD Tools ──────────────────────────────────────────────
# Expose direct DB read/write to the AI agent via MCP CRUD tools.
# Keep disabled in production unless you fully trust your users and LLM.
CRUD_TOOLS_ENABLED=false
# Allow write operations (create/update/delete) via CRUD tools.
# Even with CRUD_TOOLS_ENABLED=true, writes are blocked unless this is also true.
CRUD_TOOLS_ALLOW_WRITE=false

# ── DataStore ────────────────────────────────────────────────
# Enables org-scoped dynamic data stores: named stores with optional JSON Schema
# validation, accessible via MCP tool (LLM) and REST API.
# Disabled by default — enable in trusted environments where agents need
# persistent structured storage across sessions.
DATASTORE_ENABLED=false
# Maximum number of active stores per organization.
DATASTORE_MAX_STORES_PER_ORG=20
# Maximum number of records per store.
DATASTORE_MAX_RECORDS_PER_STORE=1000
# Maximum serialised size of a single record payload (bytes). Default: 10 KB.
DATASTORE_MAX_RECORD_SIZE_BYTES=10240

# ── Bootstrap admin ─────────────────────────────────────────
# Creates the initial organization and admin user on first startup.
# Also generates an API key for the admin user (printed in logs once).
# Leave ADMIN_EMAIL empty to skip bootstrap entirely.
ADMIN_EMAIL=admin@gsage.local
ADMIN_PASSWORD=CHANGE-ME-admin-password
ADMIN_ORG_NAME=gSage

# ── Self registration TAKE CARE  ─────────────────────────────────────────
# If allowed, non authenticated user can create user and use your env
ALLOW_SELF_REGISTER=false

# ── SMTP (outgoing email) ─────────────────────────────────────────────────
# Used for approval notification emails and other system messages.
# Leave SMTP_HOST empty to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# Validate TLS server certificate.  Set to false only for internal relays
# using self-signed certificates.  Default: true.
SMTP_VALIDATE_CERTS=true
SMTP_FROM_EMAIL=noreply@gsage.local
SMTP_FROM_NAME="gSage AI"
# Default body rendering: "html" (Markdown auto-detected) or "text" (plain only)
SMTP_DEFAULT_FORMAT=html

# ── Telegram Bot Worker ──────────────────────────────────────
# Bot tokens are stored per-org in InterfaceProfile.interface_config.bot_token.
# The variables below control global rate limits and behaviour.
# Org-level daily message limit (across all users of that org).
TELEGRAM_RATE_LIMIT_ORG_DAILY=200
# Per-user hourly message limit.
TELEGRAM_RATE_LIMIT_USER_HOURLY=30
# Maximum outgoing message length (Telegram hard cap = 4096).
TELEGRAM_MAX_MESSAGE_LENGTH=4096
# Seconds between DB hot-reload cycles (re-query active InterfaceProfiles).
# Set to 0 to disable periodic reload.
TELEGRAM_RELOAD_INTERVAL=300

# ── Microsoft Teams Channel ───────────────────────────────────
# Azure Bot credentials are stored per-org in InterfaceProfile.interface_config
# (app_id, app_password, tenant_id). The webhook lives at
# /api/v1/channels/teams/{profile_id}/messages and JWTs are validated by the
# Bot Framework adapter against each profile's app_id.
# Org-level daily message limit (across all users of that org).
TEAMS_RATE_LIMIT_ORG_DAILY=200
# Per-user hourly message limit.
TEAMS_RATE_LIMIT_USER_HOURLY=30
# Maximum outgoing message length (Teams cap is generous; we split above this).
TEAMS_MAX_MESSAGE_LENGTH=25000
# OpenID metadata document the Bot Framework SDK uses to validate inbound JWTs.
# Default is the public Microsoft endpoint; only override for sovereign clouds.
TEAMS_BOT_OPENID_METADATA_URL=https://login.botframework.com/v1/.well-known/openidconfiguration
# How long to cache Microsoft Graph email→AAD lookups in Redis (seconds).
TEAMS_GRAPH_EMAIL_CACHE_TTL=86400

# ── Email Worker ──────────────────────────────────────────────────────────────
# Org-level daily inbound email processing limit (across all users of that org).
EMAIL_RATE_LIMIT_ORG_DAILY=100
# Per-user hourly new-thread rate limit.
EMAIL_RATE_LIMIT_USER_HOURLY=10
# When true, emails are permanently deleted from the IMAP server after being
# read and dispatched to the agent. When false (default), they are only
# marked as \Seen so they remain in the mailbox but won't be re-fetched.
EMAIL_DELETE_AFTER_PROCESS=false
# IMAP folder to receive emails from unknown senders (no matching user in the
# org). The folder is auto-created on first use.
EMAIL_UNKNOWN_SENDER_FOLDER=Unknown-Senders
# ── Curator (Reputation Lists) ────────────────────────────────────────────
# PostgreSQL user and database for the curator service.
# The init-curator.sh script creates this user/database on first postgres start.
CURATOR_DB_USER=curator
CURATOR_DB_PASSWORD=CHANGE-ME-curator-password
# Full async DSN used by the curator FastAPI app.
CURATOR_DATABASE_URI=postgresql+asyncpg://curator:CHANGE-ME-curator-password@postgres:5432/curator
# API key protecting the /a/ admin endpoints.
CURATOR_API_KEY=CHANGE-ME-curator-api-key
# Seconds to wait after the last write before triggering a dump (debounce).
CURATOR_WAIT_TIME=10
# Seconds between expired-item cleanup runs.
CURATOR_EXPIRY_CHECK_INTERVAL=3600
# ── Wiki.js (Documentation Wiki) ─────────────────────────────────────────
# PostgreSQL user/password for the wikijs database.
# The init-wikijs.sh script creates this user/database on first postgres start.
WIKIJS_DB_USER=wikijs
WIKIJS_DB_PASSWORD=CHANGE-ME-wikijs-password
# Port exposed to the host for the Wiki.js admin setup wizard (default: 8082).
WIKIJS_PORT=8082
# Internal Wiki.js URL (used by the MCP tool — must be reachable from within gsage-internal).
# Configure via the tool config:
TOOL_WIKIJS_EDITOR__URL=http://wikijs:3000
# Bearer token for the Wiki.js GraphQL API.
# Generate it in the Wiki.js admin area: Administration > API Access > New API Key.
TOOL_WIKIJS_EDITOR__API_TOKEN=
# Path prefix within Wiki.js that the wikijs_editor tool is allowed to write to.
# Pages outside this prefix are read-only for the tool.
TOOL_WIKIJS_EDITOR__WRITABLE_PATH=gsage/
# Default locale for Wiki.js page operations (e.g. en, pt, es).
TOOL_WIKIJS_EDITOR__LOCALE=en
# ── MinIO (object storage — tool-generated files) ───────────
# MinIO does NOT need to be externally reachable — files are streamed
# to clients via the backend API proxy (GET /v1/orgs/{org_id}/files/{id}/download).
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=gsage
MINIO_SECRET_KEY=CHANGE-ME-strong-password
MINIO_SECURE=false
MINIO_BUCKET=gsage-artifacts
# Bucket for storing original knowledge base files (for download after ingestion)
MINIO_KB_ORIGINALS_BUCKET=gsage-kb-originals
# When running the admin console directly on the host (outside Docker), set
# this to the host-accessible MinIO endpoint so browse operations work.
# ADMIN_MINIO_ENDPOINT=localhost:9000

# ── Tool-Generated Files (TTL & Limits) ──────────────────────
# TTL in hours before generated files expire (default: 72)
# FILE_DEFAULT_TTL_HOURS=72
# Maximum upload size in bytes (default: 1073741824 = 1 GB)
# Must be aligned with nginx ``client_max_body_size`` in web_client/nginx*.conf.
# FILE_MAX_SIZE_BYTES=1073741824

# ── Custom Extensions ─────────────────────────────────────────
# Python package containing custom BaseTool subclasses (default: custom_code.tools)
# Set to empty to disable custom tool loading.
# CUSTOM_TOOLS_MODULE=custom_code.tools

# ── Tool filtering ────────────────────────────────────────────
# Restrict which tools are loaded by the MCP registry at startup.
# Comma-separated patterns. Empty = no filter (all tools load).
# DISABLED always wins over ENABLED (deny > allow).
#
# Pattern syntax (per entry):
#   <glob>              matches tool.name (fnmatch: *, ?, [abc])
#   name:<glob>         matches tool.name (explicit)
#   category:<glob>     matches tool.category
#   module:<glob>       matches python module path (skipped pre-import)
#   core:true|false     matches tool.core_tool flag
#   re:<regex>          regex against tool.name
#
# Examples:
#   Basic install (only core + DNS + ELK):
#     TOOLS_ENABLED=core:true,dns_*,elk_*
#   Everything except CRUD and document generation:
#     TOOLS_DISABLED=category:crud,module:*.document_generation.*
#   Disable a single tool:
#     TOOLS_DISABLED=pcap_analyzer
#
# TOOLS_ENABLED=
# TOOLS_DISABLED=

# ── Binary Databases (GeoIP, IP2Location, …) ─────────────────
# Root directory for binary database files mounted via Docker volume.
# Run dbs/<category>/update.sh to populate.
# GSAGE_DBS_PATH=/app/dbs

# ── Tool Config Defaults ──────────────────────────────────────
# Per-tool environment variable defaults. Convention: TOOL_{TOOL_NAME}__{FIELD}
# These are used when no per-org config exists in the database.
# Sensitive fields (API keys) should be stored in the database instead.
# Run: python scripts/generate_tool_env_defaults.py  to refresh this section.
#
# ── HITL auto-approval ────────────────────────────────────────
# For every tool that declares requires_approval=True, the backend exposes a
# per-tool toggle that bypasses Human-in-the-Loop review. Resolution order
# (highest precedence first): per-org DB toolconfig (profile=default) →
# env var TOOL_<TOOL_NAME>__AUTO_APPROVE → default (false).
# Use only in lab/dev. Examples:
# TOOL_SEI_WRITE__AUTO_APPROVE=false
# TOOL_AD_WRITE__AUTO_APPROVE=false
#
# ── BEGIN TOOL DEFAULTS (auto-generated — do not edit manually) ──────────────
# ── tool_namespace:active_directory (shared by: ad_read, ad_write) ──────
# Base DN used as default search root for reads and as the organizational scope for protected-list matching. Example: 'DC=corp,DC=contoso,DC=local'.
# TOOL_ACTIVE_DIRECTORY__BASE_DN=
# AD domain DNS name, e.g. 'corp.contoso.local'.
# TOOL_ACTIVE_DIRECTORY__DOMAIN=
# DN of the read-only service account used by ad_read.
# TOOL_ACTIVE_DIRECTORY__LDAP_BIND_DN=
# Password for ldap_bind_dn (stored encrypted).
# TOOL_ACTIVE_DIRECTORY__LDAP_BIND_PASSWORD=
# Connection + operation timeout (seconds).
# TOOL_ACTIVE_DIRECTORY__LDAP_CONNECT_TIMEOUT_SECONDS=10
# LDAP(S) server URL used by ad_read. Example: 'ldaps://dc01.corp.contoso.local:636'.
# TOOL_ACTIVE_DIRECTORY__LDAP_URL=
# Validate the LDAP server TLS certificate. Default true.
# TOOL_ACTIVE_DIRECTORY__LDAP_VERIFY_SSL=true
# When true, ad_write appends a single-line action log to the target object's 'description' attribute after success. Format: '[YYYY-MM-DD HH:MM UTC] <action> by gSage: <summary>'.
# TOOL_ACTIVE_DIRECTORY__LOG_ACTIONS_IN_DESCRIPTION=false
# Length of passwords generated by reset_password.
# TOOL_ACTIVE_DIRECTORY__PASSWORD_POLICY_LENGTH=16
# Groups that ad_write MUST NEVER modify. Matches CN, full DN, or fnmatch glob (case-insensitive). Also blocks group membership changes where either side is protected.
# TOOL_ACTIVE_DIRECTORY__PROTECTED_GROUPS=['Domain Admins', 'Enterprise Admins', 'Schema Admins', 'Administrators']
# Users that ad_write MUST NEVER touch. Matches sAMAccountName, full DN, or fnmatch glob (case-insensitive).
# TOOL_ACTIVE_DIRECTORY__PROTECTED_USERS=['Administrator', 'krbtgt', 'Guest']
# OU DN where disabled users are moved when disable_user is called with move_to_quarantine=true. Example: 'OU=Disabled Users,DC=corp,DC=contoso,DC=local'.
# TOOL_ACTIVE_DIRECTORY__QUARANTINE_OU=
# Maximum time to wait for a pwsh script to complete.
# TOOL_ACTIVE_DIRECTORY__SSH_COMMAND_TIMEOUT_SECONDS=60
# Windows jump host (FQDN or IP) with OpenSSH Server, PowerShell 7, and the RSAT ActiveDirectory module installed.
# TOOL_ACTIVE_DIRECTORY__SSH_HOST=
# Optional OpenSSH known_hosts content used to pin the jump host's public key. When empty, host-key checking is disabled (operator is responsible for the network path).
# TOOL_ACTIVE_DIRECTORY__SSH_KNOWN_HOSTS=
# SSH port on the jump host (default 22).
# TOOL_ACTIVE_DIRECTORY__SSH_PORT=22
# PEM/OpenSSH private key content for ssh_user (stored encrypted). Passphrase-less keys only.
# TOOL_ACTIVE_DIRECTORY__SSH_PRIVATE_KEY=
# Local Windows / AD user that PowerShell should impersonate. Must have permission to run the AD cmdlets used by ad_write.
# TOOL_ACTIVE_DIRECTORY__SSH_USER=
# Master switch for ad_write. When false, every write action fails with CONFIG_WRITE_DISABLED. Default false.
# TOOL_ACTIVE_DIRECTORY__WRITE_ENABLED=false

# ── tool_namespace:azure (shared by: azure_costs, azure_dashboard, azure_inventory, azure_manage, azure_metrics) ──
# Service Principal application (client) ID.
# TOOL_AZURE__CLIENT_ID=
# Service Principal secret (sensitive).
# TOOL_AZURE__CLIENT_SECRET=
# Azure cloud environment (default 'AzurePublicCloud').
# TOOL_AZURE__CLOUD_ENVIRONMENT=AzurePublicCloud
# Optional default resource group used by management actions when not provided in params.
# TOOL_AZURE__DEFAULT_RESOURCE_GROUP=
# Subscription used when the caller omits 'params.subscription_id'.
# TOOL_AZURE__DEFAULT_SUBSCRIPTION_ID=
# Microsoft Entra ID (Azure AD) tenant ID (UUID).
# TOOL_AZURE__TENANT_ID=
# HTTP request timeout in seconds (default 60).
# TOOL_AZURE__TIMEOUT=60

# ── tool_namespace:curator (shared by: curator_lists, curator_manage) ───
# Curator admin API key (X-API-Key header).
# TOOL_CURATOR__API_KEY=
# Curator service base URL (default: http://curator:8000).
# TOOL_CURATOR__BASE_URL=http://curator:8000

# ── tool_namespace:gitlab (shared by: gitlab_dashboard, gitlab_manage, gitlab_read) ──
# Default page size for paginated requests (default: 20).
# TOOL_GITLAB__DEFAULT_PER_PAGE=20
# Optional HTTP/HTTPS proxy URL.
# TOOL_GITLAB__PROXY=
# HTTP request timeout in seconds (default: 30).
# TOOL_GITLAB__TIMEOUT=30
# Personal Access Token (PAT).  Needs 'read_api' scope for gitlab_read and 'api' scope for gitlab_manage.
# TOOL_GITLAB__TOKEN=
# Base URL of the GitLab instance, e.g. 'https://gitlab.com' or 'https://git.yourcompany.com'.  Must NOT include /api/v4.
# TOOL_GITLAB__URL=
# Verify TLS certificate of the GitLab server (default: true).
# TOOL_GITLAB__VERIFY_SSL=true

# ── tool_namespace:glpi (shared by: glpi_create_ticket, glpi_dashboard, glpi_get_group_members, glpi_get_item, glpi_search, glpi_update_ticket) ──
# GLPI application token.
# TOOL_GLPI__APP_TOKEN=
# GLPI REST API base URL.
# TOOL_GLPI__URL=
# GLPI user token.
# TOOL_GLPI__USER_TOKEN=

# ── tool_namespace:gravityzone (shared by: gz_endpoints, gz_management, gz_security) ──
# GravityZone API key (from Control Center → My Account → API keys).
# TOOL_GRAVITYZONE__API_KEY=
