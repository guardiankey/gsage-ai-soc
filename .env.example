# TOOL_ELK_SEARCH__ALLOWED_INDEX_PATTERNS=[]
# Base64 API key (id:secret) issued by Kibana → Stack Management → API keys. Optional: leave empty for unauthenticated clusters (e.g. lab / internal networks). Username/password auth is not supported in V1.
