# TOOL_GRAVITYZONE__BASE_URL=https://cloud.gravityzone.bitdefender.com/api

# ── tool_namespace:kubernetes (shared by: k8s_dashboard, k8s_manage, k8s_observe) ──
# Cluster API server URL, e.g. 'https://k8s.example.com:6443'. Required unless 'in_cluster' is true.
# TOOL_KUBERNETES__API_SERVER=
# PEM-encoded CA certificate of the API server. Optional but recommended for self-signed clusters; ignored when 'verify_tls' is false.
# TOOL_KUBERNETES__CA_CERT=
# Namespace assumed when the caller omits one (default: 'default').
# TOOL_KUBERNETES__DEFAULT_NAMESPACE=default
# When true, use the pod's mounted ServiceAccount credentials (ignores api_server / token / ca_cert). Default: false.
# TOOL_KUBERNETES__IN_CLUSTER=false
# HTTP request timeout in seconds (default: 30).
# TOOL_KUBERNETES__TIMEOUT=30
# Service account bearer token (sensitive). Required unless 'in_cluster' is true.
# TOOL_KUBERNETES__TOKEN=
# Verify the API-server TLS certificate (default: true). Disable only for local/test clusters.
# TOOL_KUBERNETES__VERIFY_TLS=true

# ── tool_namespace:rt (shared by: rt_dashboard, rt_get_ticket, rt_manage, rt_search) ──
# Optional proxy URL (http://user:pass@host:port). Empty string disables proxy.
# TOOL_RT__PROXY=
# HTTP request timeout in seconds (default 30).
# TOOL_RT__TIMEOUT=30
# RT auth token (Settings → Auth Tokens). Sensitive.
# TOOL_RT__TOKEN=
# Base URL of the RT REST 2.0 endpoint, e.g. https://rt.example.com/REST/2.0
# TOOL_RT__URL=
# Verify TLS certificate (default true).
# TOOL_RT__VERIFY_SSL=true

# ── tool_namespace:smtp_send (shared by: send_email, send_email_direct) ──
# Optional allowlist of regex patterns.  A recipient is accepted when it matches at least one pattern or when it is one of the current user's own addresses.  When empty, the behaviour depends on the tool variant: ``send_email`` accepts any recipient (approval already gates the action); ``send_email_direct`` restricts delivery to the current user's own addresses.
# TOOL_SMTP_SEND__ALLOWED_RECIPIENTS_REGEX=
# Default body format (overrides SMTP_DEFAULT_FORMAT).
# TOOL_SMTP_SEND__SMTP_DEFAULT_FORMAT=
# Sender address in the From header (overrides SMTP_FROM_EMAIL).
# TOOL_SMTP_SEND__SMTP_FROM_EMAIL=
# Sender display name in the From header (overrides SMTP_FROM_NAME).
# TOOL_SMTP_SEND__SMTP_FROM_NAME=
# SMTP server hostname (overrides SMTP_HOST).
# TOOL_SMTP_SEND__SMTP_HOST=
# SMTP authentication password (overrides SMTP_PASSWORD).
# TOOL_SMTP_SEND__SMTP_PASSWORD=
# SMTP port (overrides SMTP_PORT).
# TOOL_SMTP_SEND__SMTP_PORT=
# Use STARTTLS for the SMTP connection (overrides SMTP_USE_TLS).
# TOOL_SMTP_SEND__SMTP_USE_TLS=
# SMTP authentication username (overrides SMTP_USERNAME).
# TOOL_SMTP_SEND__SMTP_USERNAME=
# Validate TLS server certificate (default true).  Set to false only for internal relays using self-signed certificates.
# TOOL_SMTP_SEND__SMTP_VALIDATE_CERTS=

# ── tool_namespace:trellix_edr (shared by: trellix_edr_get_host_quarantine_status, trellix_edr_quarantine_host, trellix_edr_search, trellix_edr_search_files, trellix_edr_search_network, trellix_edr_search_processes) ──
