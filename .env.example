# ── END TOOL DEFAULTS (auto-generated) ──────────────────────────────────────

# ── GuardianKey (Adaptive Authentication) ────────────────────────────────────
# Post-credential risk scoring via GuardianKey API v2. Fail-open: if the API is
# unreachable or times out, login proceeds normally. BLOCK response → 401.
# NOTIFY/HARD_NOTIFY → login proceeds + warning logged.
# Credentials: https://gdn.guardiankey.io → Settings → Authgroup → Deploy tab
GK_ENABLED=false
GK_API_URL=https://api.guardiankey.io
GK_ORG_ID=
GK_AUTHGROUP_ID=
GK_KEY=
GK_IV=
GK_AGENT_ID=gsage-ai
GK_SERVICE_NAME=gSageAI
# Perform local reverse-DNS lookup for client IP (may add latency)
GK_REVERSE_DNS=false
GK_TIMEOUT_SECONDS=4

# ── tool:ad_read / tool:ad_write (Active Directory administration) ──────────
# Shared configuration for both AD tools. Reads are performed over LDAP(S);
# writes run PowerShell scripts on a Windows jump host via SSH.
# All sensitive fields (passwords / keys) are stored encrypted in the DB
# when configured via the admin console. The TOOL_* env vars below are
# optional fallbacks used only when no GSageToolConfig row exists.
#
# AD domain and base DN
# TOOL_AD_READ__DOMAIN=corp.contoso.local
# TOOL_AD_READ__BASE_DN=DC=corp,DC=contoso,DC=local
# TOOL_AD_WRITE__DOMAIN=corp.contoso.local
# TOOL_AD_WRITE__BASE_DN=DC=corp,DC=contoso,DC=local
#
# LDAP connection (used by ad_read)
# TOOL_AD_READ__LDAP_URL=ldaps://dc01.corp.contoso.local:636
# TOOL_AD_READ__LDAP_BIND_DN=CN=svc-gsage,CN=Users,DC=corp,DC=contoso,DC=local
# TOOL_AD_READ__LDAP_BIND_PASSWORD=
# TOOL_AD_READ__LDAP_VERIFY_SSL=true
# TOOL_AD_READ__LDAP_CONNECT_TIMEOUT_SECONDS=10
#
# SSH connection to the Windows jump host (used by ad_write)
# The jump host must have: OpenSSH Server + PowerShell 7 + RSAT ActiveDirectory module
# TOOL_AD_WRITE__SSH_HOST=jump-ad.corp.contoso.local
# TOOL_AD_WRITE__SSH_PORT=22
# TOOL_AD_WRITE__SSH_USER=svc-gsage
# TOOL_AD_WRITE__SSH_PRIVATE_KEY=
# Optional OpenSSH known_hosts content for jump-host key pinning. When empty,
# host-key verification is disabled (operator is responsible for the path).
# TOOL_AD_WRITE__SSH_KNOWN_HOSTS=
# TOOL_AD_WRITE__SSH_COMMAND_TIMEOUT_SECONDS=60
#
# Master switch for writes — FAIL-CLOSED by default. Set true only after
# reviewing protected_users / protected_groups and testing ad_read first.
# TOOL_AD_WRITE__WRITE_ENABLED=false
#
# OU where users are moved on disable_user (when move_to_quarantine=true)
# TOOL_AD_WRITE__QUARANTINE_OU=OU=Disabled Users,DC=corp,DC=contoso,DC=local
#
# When true, each successful write appends a log line to the target object's
# 'description' attribute: "[UTC] <action> by gSageAI: <summary>".
# TOOL_AD_WRITE__LOG_ACTIONS_IN_DESCRIPTION=false
#
# Length of passwords generated by reset_password / create_user (8–128)
# TOOL_AD_WRITE__PASSWORD_POLICY_LENGTH=16
#
# NOTE: 'protected_users' and 'protected_groups' are arrays and must be
# configured via the admin console (not env vars). Defaults block:
#   users:  Administrator, krbtgt, Guest
#   groups: Domain Admins, Enterprise Admins, Schema Admins, Administrators

# ── BEGIN AUTH PROVIDER DEFAULTS (auto-generated — do not edit manually) ─────
# ── auth_provider:entra_oidc ────────────────────────────────────────────
# Auto-create GSageDepartment records when a group_mapping entry references a department that does not yet exist.
# AUTH_ENTRA_OIDC__AUTO_CREATE_DEPARTMENTS=false
# Auto-create GSageGroup records for mapped groups.
# AUTH_ENTRA_OIDC__AUTO_CREATE_GROUPS=true
# When False, refuse logins from users who do not already exist locally.
# AUTH_ENTRA_OIDC__AUTO_PROVISION_USERS=true
# Application (client) ID from the Entra app registration.
# AUTH_ENTRA_OIDC__CLIENT_ID=
# Client secret value from the Entra app registration.
# AUTH_ENTRA_OIDC__CLIENT_SECRET=
# Role assigned to users matched by no group_mapping entry.
# AUTH_ENTRA_OIDC__DEFAULT_ROLE=viewer
# Map external Entra group object IDs to local roles and groups.
# AUTH_ENTRA_OIDC__GROUP_MAPPING={}
# Optional explicit redirect URI override. Leave blank to auto-derive from public_base_url and org slug.
# AUTH_ENTRA_OIDC__REDIRECT_URI=
# Login gate: list of Entra group object IDs the user must belong to at least one of. Empty list (default) allows all.
# AUTH_ENTRA_OIDC__REQUIRED_GROUPS=[]
# Space-separated OIDC scopes.
# AUTH_ENTRA_OIDC__SCOPES=openid profile email User.Read
# Directory (tenant) ID. Use 'common' for multi-tenant.
# AUTH_ENTRA_OIDC__TENANT_ID=

# ── auth_provider:ldap ──────────────────────────────────────────────────
# Authentication method: SIMPLE | NTLM | KERBEROS
# AUTH_LDAP__AUTH_METHOD=SIMPLE
# Automatically create GSageGroup records for mapped groups
# AUTH_LDAP__AUTO_CREATE_GROUPS=true
# Service account DN used for user/group searches
# AUTH_LDAP__BIND_DN=
# Service account password
# AUTH_LDAP__BIND_PASSWORD=
# LDAP connection timeout in seconds
# AUTH_LDAP__CONNECT_TIMEOUT_SECONDS=10
# Role assigned to users matched by no group_mapping entry
# AUTH_LDAP__DEFAULT_ROLE=viewer
# Map external LDAP group DNs to local roles and groups
# AUTH_LDAP__GROUP_MAPPING={}
# LDAP base DN for group searches (leave empty to skip group sync)
# AUTH_LDAP__GROUP_SEARCH_BASE=
# LDAP filter with {user_dn} placeholder, e.g. (member={user_dn})
# AUTH_LDAP__GROUP_SEARCH_FILTER=(member={user_dn})
# Kerberos realm, e.g. CORP.EXAMPLE.COM (KERBEROS method only)
# AUTH_LDAP__KERBEROS_REALM=
# NTLM domain prefix, e.g. CORP (NTLM method only)
# AUTH_LDAP__NTLM_DOMAIN=
# Login gate: list of LDAP group DNs the user must belong to at least one of. Empty list (default) allows all valid LDAP users.
# AUTH_LDAP__REQUIRED_GROUPS=[]
# Resolve nested (transitive) group memberships via memberOf:1.2.840.113556.1.4.1941:
# AUTH_LDAP__RESOLVE_NESTED_GROUPS=false
# LDAP(S) URL, e.g. ldaps://dc.corp.example.com:636
# AUTH_LDAP__SERVER_URL=
# Validate TLS certificate (set false only in dev/lab)
# AUTH_LDAP__TLS_VALIDATE=true
# Use LDAPS or STARTTLS
# AUTH_LDAP__USE_TLS=true
# LDAP base DN for user searches
# AUTH_LDAP__USER_SEARCH_BASE=
# LDAP filter with {username} placeholder, e.g. (sAMAccountName={username})
# AUTH_LDAP__USER_SEARCH_FILTER=(sAMAccountName={username})

# ── END AUTH PROVIDER DEFAULTS (auto-generated) ──────────────────────────────
